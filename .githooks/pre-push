#!/bin/bash
# .githooks/pre-push — Opt-in local gate.
# Install with: git config core.hooksPath .githooks
#
# Runs the source-level wiring guards (same as CI) and optionally
# the simulator test suite. Set VOXGLASS_SKIP_TESTS=1 to skip
# the simulator suite (it takes minutes).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo ""
echo "=== pre-push guard ==="

echo ""
echo "--- guard_wiring.sh ---"
if ! bash scripts/guard_wiring.sh; then
  echo ""
  echo "Wiring guards failed. Fix the violations before pushing."
  echo "(You can still push with --no-verify, but CI will block the PR.)"
  exit 1
fi

if [ "${VOXGLASS_SKIP_TESTS:-0}" = "1" ]; then
  echo ""
  echo "Skipping simulator test suite (VOXGLASS_SKIP_TESTS=1)."
  exit 0
fi

echo ""
echo "--- simulator test suite ---"
echo "This takes a couple of minutes. Set VOXGLASS_SKIP_TESTS=1 to skip."
bash scripts/test.sh
